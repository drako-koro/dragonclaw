{
  "server": {
    "port": 3847,
    "host": "127.0.0.1"
  },
  "security": {
    "permissionPreset": "standard",
    "requireAuth": true
  },
  "ai": {
    "maxHistoryMessages": 20,
    "defaultTemperature": 0.7,
    "ollama": {
      "enabled": true,
      "endpoint": "http://localhost:11434",
      "model": "qwen3.5:35b",
      "defaultModel": "qwen3.5:35b",
      "models": {
        "planning": "deepseek-r1:32b",
        "drafting": "qwen3.5:35b",
        "critique": "deepseek-r1:32b",
        "rewrite": "mistral-small3.2:24b",
        "final": "deepseek-r1:32b"
      },
      "thinking": {
        "planning": true,
        "drafting": false,
        "critique": true,
        "rewrite": false,
        "final": true
      },
      "maxTokens": 4096,
      "requestTimeoutMs": 600000
    },
    "gemini": {
      "model": "gemini-2.5-flash"
    },
    "deepseek": {
      "model": "deepseek-chat"
    },
    "claude": {
      "model": "claude-sonnet-4-5-20250929"
    },
    "openai": {
      "model": "gpt-4o"
    }
  },
  "memory": {
    "maxConversationHistory": 50,
    "maxMemoryEntries": 200,
    "autoSummarize": true
  },
  "heartbeat": {
    "intervalMinutes": 15,
    "dailyWordGoal": 1000,
    "enableReminders": true,
    "quietHoursStart": 0,
    "quietHoursEnd": 0
  },
  "costs": {
    "dailyLimit": 5,
    "monthlyLimit": 50,
    "alertAt": 0.8
  },
  "bridges": {
    "telegram": {
      "enabled": false,
      "allowedUsers": [],
      "pairingEnabled": true
    },
    "discord": {
      "enabled": false
    }
  },
  "branding": {
    "name": "DragonClaw",
    "tagline": "The Ember-Forged AI Writing Agent",
    "theme": "ember-forge",
    "colors": {
      "background": "#0b0909",
      "surface": "#171110",
      "border": "#3b2419",
      "accent": "#ff6a1a",
      "accentGlow": "#ff9b45",
      "text": "#f7e6d6",
      "muted": "#8c6a58"
    }
  }
}