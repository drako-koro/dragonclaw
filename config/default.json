{
  "server": {
    "port": 3847,
    "host": "127.0.0.1"
  },
  "security": {
    "permissionPreset": "standard",
    "requireAuth": true
  },
  "ai": {
    "maxHistoryMessages": 20,
    "defaultTemperature": 0.7,
    "ollama": {
      "enabled": true,
      "endpoint": "http://localhost:11434",
      "model": "llama3.2"
    },
    "gemini": {
      "model": "gemini-2.5-flash"
    },
    "deepseek": {
      "model": "deepseek-chat"
    },
    "claude": {
      "enabled": false,
      "baseUrl": "https://api.anthropic.com/v1",
      "defaultModel": "claude-sonnet-4-6",
      "models": {
        "planning": "claude-sonnet-4-6",
        "drafting": "claude-opus-4-6",
        "critique": "claude-opus-4-6",
        "rewrite": "claude-sonnet-4-6",
        "final": "claude-opus-4-6"
      },
      "thinking": {
        "planning": true,
        "drafting": false,
        "critique": true,
        "rewrite": false,
        "final": true
      },
      "thinkingEffort": {
        "planning": "medium",
        "drafting": "medium",
        "critique": "medium",
        "rewrite": "medium",
        "final": "medium"
      },
      "thinkingBudgetTokens": {
        "planning": 2048,
        "drafting": 2048,
        "critique": 2048,
        "rewrite": 2048,
        "final": 2048
      },
      "maxTokens": 4096,
      "requestTimeoutMs": 600000,
      "costPer1kInput": 0,
      "costPer1kOutput": 0
    },
    "openai": {
      "model": "gpt-4o"
    },
    "defaultProvider": "ollama",
    "providers": {
      "planning": "ollama",
      "drafting": "ollama",
      "critique": "ollama",
      "rewrite": "ollama",
      "final": "ollama"
    }
  },
  "memory": {
    "maxConversationHistory": 50,
    "maxMemoryEntries": 200,
    "autoSummarize": true
  },
  "heartbeat": {
    "intervalMinutes": 15,
    "dailyWordGoal": 1000,
    "enableReminders": true,
    "quietHoursStart": 0,
    "quietHoursEnd": 0
  },
  "costs": {
    "dailyLimit": 5,
    "monthlyLimit": 50,
    "alertAt": 0.8
  },
  "bridges": {
    "telegram": {
      "enabled": false,
      "allowedUsers": [],
      "pairingEnabled": true
    },
    "discord": {
      "enabled": false,
      "guildId": "",
      "allowedUsers": [],
      "allowedChannels": [],
      "registerSlashCommands": true,
      "pairingEnabled": true
    }
  }
}